        "jsCode": "const qa = $json;\n\nconst drive = $('Google Drive Trigger').first().json;\nconst transcription = $('Transcribe a recording').first().json;\n\nconst fileId = drive.id ?? '';\nconst fileName = drive.name ?? '';\n\nconst transcriptText =\n  transcription.text ??\n  transcription.transcription ??\n  transcription.output ??\n  '';\n\nconst duration =\n  transcription.duration ??\n  transcription.audio_duration ??\n  transcription.metadata?.duration ??\n  '';\n\nreturn [\n  {\n    json: {\n      processed_at: new Date().toISOString(),\n\n      file_name: fileName,\n      file_id: fileId,\n      file_url: fileId\n        ? `https://drive.google.com/file/d/${fileId}/view`\n        : '',\n\n      call_duration: duration,\n      transcription: transcriptText,\n\n      overall_score: qa.overall_score,\n      rating_band: qa.rating_band,\n      positive_feedback: qa.positive_feedback,\n      negative_feedback: qa.negative_feedback,\n\n      greetings_score: qa.greetings_score,\n      greetings_comment: qa.greetings_comment,\n\n      active_listening_score: qa.active_listening_score,\n      active_listening_comment: qa.active_listening_comment,\n\n      needs_discovery_score: qa.needs_discovery_score,\n      needs_discovery_comment: qa.needs_discovery_comment,\n\n      empathy_score: qa.empathy_score,\n      empathy_comment: qa.empathy_comment,\n\n      expert_knowledge_score: qa.expert_knowledge_score,\n      expert_knowledge_comment: qa.expert_knowledge_comment,\n\n      clear_solution_score: qa.clear_solution_score,\n      clear_solution_comment: qa.clear_solution_comment,\n\n      next_steps_score: qa.next_steps_score,\n      next_steps_comment: qa.next_steps_comment,\n\n      end_of_talk_score: qa.end_of_talk_score,\n      end_of_talk_comment: qa.end_of_talk_comment,\n\n      alert_sent: ''\n    },\n  },\n];"
