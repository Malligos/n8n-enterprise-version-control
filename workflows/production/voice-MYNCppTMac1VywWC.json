    {
      "parameters": {
        "jsCode": "const raw =\n  $json.output?.[0]?.content?.[0]?.text ??\n  $json.text ??\n  '';\n\nif (!raw) {\n  throw new Error('AI response is empty');\n}\n\nconst cleaned = String(raw)\n  .replace(/```json/gi, '')\n  .replace(/```/g, '')\n  .trim();\n\nlet parsed;\n\ntry {\n  parsed = JSON.parse(cleaned);\n} catch (error) {\n  throw new Error(`AI returned invalid JSON: ${cleaned}`);\n}\n\nreturn [\n  {\n    json: {\n      overall_score: Number(parsed.overall_score),\n      rating_band: parsed.rating_band,\n      positive_feedback: parsed.positive_feedback,\n      negative_feedback: parsed.negative_feedback,\n\n      greetings_score: Number(parsed.greetings?.score),\n      greetings_comment: parsed.greetings?.comment,\n\n      active_listening_score: Number(parsed.active_listening?.score),\n      active_listening_comment: parsed.active_listening?.comment,\n\n      needs_discovery_score: Number(parsed.needs_discovery?.score),\n      needs_discovery_comment: parsed.needs_discovery?.comment,\n\n      empathy_score: Number(parsed.empathy?.score),\n      empathy_comment: parsed.empathy?.comment,\n\n      expert_knowledge_score: Number(parsed.expert_knowledge?.score),\n      expert_knowledge_comment: parsed.expert_knowledge?.comment,\n\n      clear_solution_score: Number(parsed.clear_solution?.score),\n      clear_solution_comment: parsed.clear_solution?.comment,\n\n      next_steps_score: Number(parsed.next_steps?.score),\n      next_steps_comment: parsed.next_steps?.comment,\n\n      end_of_talk_score: Number(parsed.end_of_talk?.score),\n      end_of_talk_comment: parsed.end_of_talk?.comment,\n    },\n  },\n];"
      },
