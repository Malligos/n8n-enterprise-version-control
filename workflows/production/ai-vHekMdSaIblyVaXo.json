      "parameters": {
        "jsCode": "const supplierName = $node[\"Parse Draft\"].json.supplier.name.toLowerCase();\n\nconst suppliers = $json.suppliers || $json;\n\nconst found = suppliers.find(s =>\n  s.name?.toLowerCase().includes(supplierName) ||\n  supplierName.includes(s.name?.toLowerCase())\n);\n\nif (!found) {\n  throw new Error(`Поставщик не найден: ${supplierName}`);\n}\n\nreturn [{\n  json: {\n    ...$node[\"Parse Draft\"].json,\n    supplierId: found.id,\n    supplierMatchedName: found.name\n  }\n}];"
      },
