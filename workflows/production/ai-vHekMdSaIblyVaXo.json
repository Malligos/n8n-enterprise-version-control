    {
      "parameters": {
        "jsCode": "const invoiceData = $node[\"Parse Draft\"].json;\nconst products = $json.products || $json;\n\nconst matchedItems = [];\nconst unmatchedItems = [];\n\nfor (const item of invoiceData.items) {\n  const itemName = item.product_name.toLowerCase();\n\n  const found = products.find(p =>\n    p.name?.toLowerCase() === itemName ||\n    p.name?.toLowerCase().includes(itemName) ||\n    itemName.includes(p.name?.toLowerCase())\n  );\n\n  if (found) {\n    matchedItems.push({\n      productId: found.id,\n      productName: found.name,\n      quantity: item.quantity,\n      unit: item.unit,\n      price: item.price_per_unit,\n      sum: item.line_total,\n      originalName: item.product_name\n    });\n  } else {\n    unmatchedItems.push(item);\n  }\n}\n\nreturn [{\n  json: {\n    ...invoiceData,\n    matchedItems,\n    unmatchedItems\n  }\n}];"
      },
