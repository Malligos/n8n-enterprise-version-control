    {
      "parameters": {
        "jsCode": "const input = $json;\n\nlet raw =\n  input.output?.[0]?.content?.[0]?.text ||\n  input.content?.[0]?.text ||\n  input.text ||\n  input.output ||\n  input.message?.content ||\n  '';\n\nif (typeof raw !== 'string') {\n  raw = JSON.stringify(raw);\n}\n\nraw = raw\n  .replace(/```json/g, '')\n  .replace(/```/g, '')\n  .trim();\n\nconst start = raw.indexOf('{');\nconst end = raw.lastIndexOf('}');\n\nif (start === -1 || end === -1) {\n  throw new Error('JSON not found in AI response');\n}\n\nconst jsonString = raw.slice(start, end + 1);\nconst parsed = JSON.parse(jsonString);\n\nreturn [\n  {\n    json: {\n      supplier: parsed.supplier,\n      invoice: parsed.invoice,\n      items: parsed.items,\n      confidence: parsed.confidence || {},\n      warnings: parsed.warnings || [],\n      status: 'draft',\n      created_at: new Date().toISOString(),\n      telegram_chat_id: input.telegram_chat_id || 1679040654,\n      telegram_message_id: input.telegram_message_id || 2\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        224,
        -288
      ],
      "id": "5e44c7ab-0959-4210-8df7-025d7a8e6568",
      "name": "Clean AI JSON"
    },
    {
      "parameters": {
        "jsCode": "let data = $json;\n\n// Если вдруг пришёл сырой ответ AI\nif (!data.supplier && data.content?.[0]?.text) {\n  const raw = data.content[0].text;\n  const jsonString = raw.slice(raw.indexOf('{'), raw.lastIndexOf('}') + 1);\n  data = JSON.parse(jsonString);\n}\n\nconst errors = [];\nconst warnings = data.warnings || [];\n\nif (!data.supplier?.name) {\n  errors.push('Не найден поставщик');\n}\n\nif (!data.items || !Array.isArray(data.items) || data.items.length === 0) {\n  errors.push('Не найдены товары');\n}\n\nif (!data.invoice?.number) {\n  warnings.push('Не найден номер накладной');\n}\n\nif (!data.invoice?.date) {\n  warnings.push('Не найдена дата накладной');\n}\n\nfor (const [index, item] of (data.items || []).entries()) {\n  if (!item.product_name) {\n    errors.push(`Позиция ${index + 1}: не найдено название товара`);\n  }\n\n  if (item.quantity === null || item.quantity === undefined) {\n    warnings.push(`Позиция ${index + 1}: не найдено количество`);\n  }\n\n  if (item.price_per_unit === null || item.price_per_unit === undefined) {\n    warnings.push(`Позиция ${index + 1}: не найдена цена`);\n  }\n}\n\nreturn [\n  {\n    json: {\n      ...data,\n      validation: {\n        is_valid: errors.length === 0,\n        errors,\n        warnings\n      }\n    }\n  }\n];"
      },
