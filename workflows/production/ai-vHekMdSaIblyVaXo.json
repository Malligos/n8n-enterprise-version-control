    {
      "parameters": {
        "jsCode": "const invoice = JSON.parse($json.data);\n\nconst items = invoice.items;\n\nconst itemsText = items\n.slice(0,10)\n.map((item,index)=>\n`${index+1}. ${item.product_name}\n${item.quantity} ${item.unit}\n× ${item.price_per_unit}`)\n.join(\"\\n\");\n\nreturn [{\njson:{\n...$json,\ntelegramMessage:`\n📦 Накладна розпізнана\n\n🏢 Постачальник:\n${$json.supplier}\n\n🧾 Номер:\n${$json.invoiceNumber}\n\n📅 Дата:\n${$json.invoiceDate}\n\n💰 Сума:\n${$json.totalSum} грн\n\n📋 Позицій:\n${items.length}\n\n${itemsText}\n\nПідтвердити внесення?\n`\n}\n}]"
