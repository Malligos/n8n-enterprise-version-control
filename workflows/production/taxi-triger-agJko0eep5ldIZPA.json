    {
      "parameters": {
        "jsCode": "const source =\n  $(\"Normalize Group Message\").first().json;\n\nconst rows = $input.all()\n  .map(item => item.json)\n  .filter(row =>\n    row &&\n    Object.keys(row).length > 0 &&\n    row.telegram_user_id\n  );\n\nconst employee = rows.find(row =>\n  String(row.telegram_user_id || \"\").trim() ===\n  String(source.telegramUserId || \"\").trim()\n);\n\nreturn [\n  {\n    json: {\n      ...source,\n      employeeFound: Boolean(employee),\n      employee: employee || null\n    }\n  }\n];"
      },
