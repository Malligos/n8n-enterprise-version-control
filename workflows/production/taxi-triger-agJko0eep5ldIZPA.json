    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const message = $json.message;\n\nif (!message) {\n  return {\n    ignore: true,\n    isTaxiCommand: false,\n    reason: \"No Telegram message\"\n  };\n}\n\nconst text = String(message.text || \"\").trim();\nconst chatType = String(message.chat?.type || \"\");\n\nconst now = new Date();\n\nconst taxiDate = new Intl.DateTimeFormat(\"en-CA\", {\n  timeZone: \"Europe/Kyiv\",\n  year: \"numeric\",\n  month: \"2-digit\",\n  day: \"2-digit\"\n}).format(now);\n\nconst taxiMarkedAt = new Intl.DateTimeFormat(\"sv-SE\", {\n  timeZone: \"Europe/Kyiv\",\n  year: \"numeric\",\n  month: \"2-digit\",\n  day: \"2-digit\",\n  hour: \"2-digit\",\n  minute: \"2-digit\",\n  second: \"2-digit\"\n}).format(now);\n\nconst isGroup =\n  chatType === \"group\" ||\n  chatType === \"supergroup\";\n\nconst isPlus = text === \"+\";\nconst isMinus = text === \"-\";\n\nreturn {\n  chatId: String(message.chat?.id || \"\"),\n  chatType,\n  chatTitle: String(message.chat?.title || \"\"),\n  messageId: message.message_id || null,\n\n  telegramUserId: String(message.from?.id || \"\"),\n  telegramUsername: String(message.from?.username || \"\"),\n  telegramFirstName: String(message.from?.first_name || \"\"),\n\n  text,\n\n  isGroup,\n  isPlus,\n  isMinus,\n\n  isTaxiCommand:\n    isGroup &&\n    (isPlus || isMinus),\n\n  taxiDate,\n  taxiMarkedAt\n};"
      },
