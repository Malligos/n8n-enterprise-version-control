          "conditions": [
            {
              "id": "abb65d7d-8e66-455f-b062-9dc9e4488ad3",
              "leftValue": "={{\n  !($json.labels ?? []).some(label =>\n    [\n      'CATEGORY_PROMOTIONS',\n      'CATEGORY_SOCIAL',\n      'SPAM',\n      'TRASH'\n    ].includes(label.id || label.name)\n  )\n  &&\n  !String($json.From || '').toLowerCase().includes('no-reply')\n  &&\n  !String($json.From || '').toLowerCase().includes('noreply')\n  &&\n  !String($json.From || '').toLowerCase().includes('mailer-daemon')\n  &&\n  !($json.labels ?? []).some(label =>\n    ['HouseBox/Processed', 'HOUSEBOX_PROCESSED'].includes(\n      label.id || label.name\n    )\n  )\n}}",
              "rightValue": "",
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
