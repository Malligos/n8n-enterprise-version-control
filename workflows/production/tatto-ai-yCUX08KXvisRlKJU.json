    {
      "parameters": {
        "jsCode": "const response =\n  $json.output?.[0]?.content?.[0]?.text || '';\n\nlet clean = response.trim();\n\n// Удаляем markdown блоки ```json ```\nclean = clean.replace(/```json/gi, '');\nclean = clean.replace(/```/g, '');\nclean = clean.trim();\n\nlet data;\n\ntry {\n  data = JSON.parse(clean);\n} catch (e) {\n  return [{\n    json: {\n      ready: false,\n\n      chat_id:\n        $('Telegram Trigger').first().json.message.chat.id,\n\n      message:\n        '❌ Не вдалося розпізнати відповідь. Напишіть, наприклад: кольорова, середня, 4 години'\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    ...data,\n\n    chat_id:\n      $('Telegram Trigger').first().json.message.chat.id,\n\n    username:\n      $('Telegram Trigger').first().json.message.from.username ||\n      $('Telegram Trigger').first().json.message.from.first_name ||\n      ''\n  }\n}];"
      },
