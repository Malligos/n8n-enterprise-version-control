    {
      "parameters": {
        "jsCode": "const ai = $('Parse AI JSON').first().json;\n\nconst hours = Number(String(ai.hours).replace(',', '.'));\nconst type = String(ai.type || '').toLowerCase().trim();\nconst complexity = String(ai.complexity || '').toLowerCase().trim();\n\nconst settingsRows = $('Get Settings').all().map(i => i.json);\nconst consumablesRows = $('Get Consumables').all().map(i => i.json);\nconst normsRows = $('Get Usage Norms').all().map(i => i.json);\n\nfunction n(value) {\n  return Number(value || 0);\n}\n\nfunction r(value) {\n  return Math.round(value);\n}\n\nconst settings = {};\nfor (const row of settingsRows) {\n  settings[row.key] = n(row.value);\n}\n\nconst prices = {};\nfor (const row of consumablesRows) {\n  const name = String(row['назва'] || '').trim();\n  prices[name] = n(row['ціна_за_одиницю']);\n}\n\nconst norm = normsRows.find(row =>\n  String(row['тип'] || '').toLowerCase().trim() === type &&\n  String(row['складність'] || '').toLowerCase().trim() === complexity\n);\n\nif (!norm) {\n  return [{\n    json: {\n      success: false,\n      chat_id: ai.chat_id,\n      message: `❌ Не знайдено норму витрат для ${type} / ${complexity}`\n    }\n  }];\n}\n\nconst details = {\n  голки: n(norm['голки']) * n(prices['Голка']),\n  картриджі: n(norm['картриджі']) * n(prices['Картридж']),\n  фарба_чорна: n(norm['фарба_чорна_мл']) * n(prices['Фарба чорна']),\n  фарба_кольорова: n(norm['фарба_кольорова_мл']) * n(prices['Фарба кольорова']),\n  рукавички: n(norm['рукавички_пари']) * n(prices['Рукавички']),\n  плівка: n(norm['плівка_м']) * n(prices['Плівка']),\n  ковпачки: n(norm['ковпачки']) * n(prices['Ковпачки']),\n  серветки: n(norm['серветки']) * n(prices['Серветки']),\n  вазелін: n(norm['вазелін_г']) * n(prices['Вазелін']),\n  дезінфектор: n(norm['дезінфектор_мл']) * n(prices['Дезінфектор']),\n  пелюшки: n(norm['пелюшки']) * n(prices['Одноразова пелюшка']),\n  барєрний_захист: n(norm['барєрний_захист'] || norm['барерний_захист'] || norm['бар’єрний_захист']) * n(prices['Бар’єрний захист'])\n};\n\nconst consumablesTotal = Object.values(details).reduce((sum, value) => sum + value, 0);\n\nconst fixedCostsMonth =\n  n(settings.rent_month) +\n  n(settings.utilities_month) +\n  n(settings.ads_month) +\n  n(settings.equipment_month);\n\nconst workHoursMonth = n(settings.work_hours_month) || 120;\nconst masterRateHour = n(settings.master_rate_hour) || 700;\nconst profitMargin = n(settings.profit_margin) || 20;\n\nconst studioCost = fixedCostsMonth / workHoursMonth * hours;\nconst masterPay = masterRateHour * hours;\nconst costPrice = consumablesTotal + studioCost + masterPay;\nconst finalPrice = costPrice * (1 + profitMargin / 100);\nconst profit = finalPrice - costPrice;\n\nreturn [{\n  json: {\n    success: true,\n    дата: new Date().toISOString().split('T')[0],\n    chat_id: ai.chat_id,\n    username: ai.username,\n    години: hours,\n    тип: type,\n    складність: complexity,\n\n    голки: r(details.голки),\n    картриджі: r(details.картриджі),\n    фарба_чорна: r(details.фарба_чорна),\n    фарба_кольорова: r(details.фарба_кольорова),\n    рукавички: r(details.рукавички),\n    плівка: r(details.плівка),\n    ковпачки: r(details.ковпачки),\n    серветки: r(details.серветки),\n    вазелін: r(details.вазелін),\n    дезінфектор: r(details.дезінфектор),\n    пелюшки: r(details.пелюшки),\n    барєрний_захист: r(details.барєрний_захист),\n\n    витратники_всього: r(consumablesTotal),\n    студійні_витрати: r(studioCost),\n    оплата_майстра: r(masterPay),\n    собівартість: r(costPrice),\n    фінальна_ціна: r(finalPrice),\n    прибуток: r(profit)\n  }\n}];"
      },
