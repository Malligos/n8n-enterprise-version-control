    {
      "parameters": {
        "jsCode": "const recipeRows = $('Get Recipe').all();\nconst ingredientRows = $('Get Ingredients').all();\nconst settingsRows = $('Get Settings').all();\n\nconst weight = $('Parse Message').first().json.weight;\nconst cake = $('Parse Message').first().json.cake;\nconst chatId = $('Parse Message').first().json.chatId;\n\nlet ingredientsCost = 0;\nlet missingIngredients = [];\n\nfor (const recipe of recipeRows) {\n  const ingredientName = String(recipe.json.Ingredient).toLowerCase().trim();\n  const amount = Number(recipe.json.Amount);\n\n  const ingredient = ingredientRows.find(i =>\n    String(i.json.Ingredient).toLowerCase().trim() === ingredientName\n  );\n\n  if (!ingredient) {\n    missingIngredients.push(ingredientName);\n    continue;\n  }\n\nconst pricePerUnit = Number(ingredient.json.PricePerUnit);\n\nif (isNaN(pricePerUnit)) {\n  missingIngredients.push(`${ingredientName} — нет PricePerUnit`);\n  continue;\n}\n\ningredientsCost += amount * pricePerUnit * weight;\n}\n\nconst settings = {};\n\nfor (const row of settingsRows) {\n  settings[row.json.Setting] = Number(row.json.Value);\n}\n\nconst packaging = settings.Packaging || 0;\nconst labor = settings.Labor || 0;\nconst lossPercent = settings.LossPercent || 0;\nconst profitPercent = settings.ProfitPercent || 0;\n\nconst losses = ingredientsCost * lossPercent / 100;\n\nconst total =\n  ingredientsCost +\n  losses +\n  packaging +\n  labor;\n\nconst salePrice =\n  total * (1 + profitPercent / 100);\n\nreturn [{\n  cake,\n  weight,\n  ingredientsCost: Number(ingredientsCost.toFixed(2)),\n  losses: Number(losses.toFixed(2)),\n  packaging,\n  labor,\n  lossPercent,\n  profitPercent,\n  total: Number(total.toFixed(2)),\n  salePrice: Number(salePrice.toFixed(2)),\n  missingIngredients,\n  chatId\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
