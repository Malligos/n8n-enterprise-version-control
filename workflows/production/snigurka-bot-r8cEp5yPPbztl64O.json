    {
      "parameters": {
        "jsCode": "const text = $json.message?.text?.trim() || '';\nconst chatId = $json.message?.chat?.id;\n\nconst lower = text.toLowerCase();\nconst cleanText = lower\n  .replace(/^\\/price\\s+/, '')\n  .replace(/^\\/cake\\s+/, '')\n  .trim();\n\nconst mode = String($('Get User Mode').first().json.mode || '').toLowerCase().trim();\n\nif (!text || !chatId) {\n  return [{\n    action: 'error',\n    chatId,\n    message: '❌ Не получил текст сообщения.'\n  }];\n}\n\n// =====================\n// PRICE MODE\n// Примеры:\n// молоко 90\n// молоко 90 1000мл\n// мука 65 1000г\n// яйца 120 10шт\n// молоко 90, мука 65 1000г, яйца 120 10шт\n// =====================\nif (mode === 'price') {\n  const lines = cleanText\n    .split(/\\n|,/)\n    .map(line => line.trim().replace(/\\s+/g, ' '))\n    .filter(Boolean);\n\n  const updates = [];\n\n  for (const line of lines) {\n    // Формат: ингредиент цена количество+единица\n    // молоко 90 1000мл\n    // мука 65 1000г\n    // яйца 120 10шт\n    const unitMatch = line.match(\n      /^(.+?)\\s+(\\d+(?:[.,]\\d+)?)\\s+(\\d+(?:[.,]\\d+)?)\\s*(г|гр|g|мл|ml|л|l|шт|pcs)$/i\n    );\n\n    if (unitMatch) {\n      let ingredient = unitMatch[1].trim();\n      let price = Number(unitMatch[2].replace(',', '.'));\n      let weight = Number(unitMatch[3].replace(',', '.'));\n      let unitRaw = unitMatch[4].toLowerCase();\n\n      let unit = unitRaw;\n\n      if (['г', 'гр', 'g'].includes(unitRaw)) {\n        unit = 'g';\n      }\n\n      if (['мл', 'ml'].includes(unitRaw)) {\n        unit = 'ml';\n      }\n\n      if (['л', 'l'].includes(unitRaw)) {\n        unit = 'ml';\n        weight = weight * 1000;\n      }\n\n      if (['шт', 'pcs'].includes(unitRaw)) {\n        unit = 'pcs';\n      }\n\n      updates.push({\n        action: 'update_price',\n        ingredient,\n        price,\n        weight,\n        unit,\n        chatId\n      });\n\n      continue;\n    }\n\n    // Формат: яйца 10шт 120\n    // количество+единица цена\n    const unitMatchAlt = line.match(\n      /^(.+?)\\s+(\\d+(?:[.,]\\d+)?)\\s*(г|гр|g|мл|ml|л|l|шт|pcs)\\s+(\\d+(?:[.,]\\d+)?)$/i\n    );\n\n    if (unitMatchAlt) {\n      let ingredient = unitMatchAlt[1].trim();\n      let weight = Number(unitMatchAlt[2].replace(',', '.'));\n      let unitRaw = unitMatchAlt[3].toLowerCase();\n      let price = Number(unitMatchAlt[4].replace(',', '.'));\n\n      let unit = unitRaw;\n\n      if (['г', 'гр', 'g'].includes(unitRaw)) {\n        unit = 'g';\n      }\n\n      if (['мл', 'ml'].includes(unitRaw)) {\n        unit = 'ml';\n      }\n\n      if (['л', 'l'].includes(unitRaw)) {\n        unit = 'ml';\n        weight = weight * 1000;\n      }\n\n      if (['шт', 'pcs'].includes(unitRaw)) {\n        unit = 'pcs';\n      }\n\n      updates.push({\n        action: 'update_price',\n        ingredient,\n        price,\n        weight,\n        unit,\n        chatId\n      });\n\n      continue;\n    }\n\n    // Старый простой формат:\n    // молоко 90\n    // по умолчанию считаем 1000 g\n    const normalMatch = line.match(\n      /^(.+?)\\s+(\\d+(?:[.,]\\d+)?)\\s*(гр|грн|uah)?$/i\n    );\n\n    if (normalMatch) {\n      updates.push({\n        action: 'update_price',\n        ingredient: normalMatch[1].trim(),\n        price: Number(normalMatch[2].replace(',', '.')),\n        weight: 1000,\n        unit: 'g',\n        chatId\n      });\n    }\n  }\n\n  if (updates.length > 0) {\n    return updates;\n  }\n}\n\n// =====================\n// CAKE MODE\n// Примеры:\n// Наполеон 2\n// наполеон 2\n// =====================\nif (mode === 'cake') {\n  const oneLine = cleanText.replace(/\\s+/g, ' ');\n\n  const match = oneLine.match(\n    /^(.+?)\\s+(\\d+(?:[.,]\\d+)?)\\s*(кг|kg)?$/i\n  );\n\n  if (match) {\n    return [{\n      action: 'calculate_cake',\n      cake: match[1].trim(),\n      weight: Number(match[2].replace(',', '.')),\n      chatId\n    }];\n  }\n}\n\nreturn [{\n  action: 'error',\n  chatId,\n  message: `❌ Неверный формат.\n\n🎂 Для торта:\nНаполеон 2\n\n💰 Для цены:\nМолоко 90\nМолоко 90 1000мл\nМука 65 1000г\nЯйца 120 10шт\n\nМожно несколько сразу:\nМолоко 90 1000мл\nМука 65 1000г\nЯйца 120 10шт`\n}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
