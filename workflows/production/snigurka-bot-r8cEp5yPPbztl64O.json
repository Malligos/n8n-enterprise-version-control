    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const row = $json;\n\nconst parsed = $('Parse Message').all()[$itemIndex].json;\n\nconst price = parsed.price;\nconst ingredient = parsed.ingredient;\nconst chatId = parsed.chatId;\n\nconst weight = Number(parsed.weight || 1000);\nconst unit = parsed.unit || 'g';\n\nconst pricePerUnit = price / weight;\n\nreturn {\n  row_number: row.row_number,\n  Ingredient: ingredient,\n  Price: price,\n  Weight: weight,\n  Unit: unit,\n  PricePerUnit: Number(pricePerUnit.toFixed(6)),\n  chatId\n};"
      },
