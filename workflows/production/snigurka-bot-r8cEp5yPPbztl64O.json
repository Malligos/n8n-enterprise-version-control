    {
      "parameters": {
        "jsCode": "const mode = $('Get User Mode').first().json.mode;\n\nconst original = $('Telegram Trigger').first().json;\n\nconst text = original.message.text.trim();\nconst chatId = original.message.chat.id;\n\n// Если режим price\nif (mode === 'price') {\n  return [{\n    message: {\n      text: `/price ${text}`,\n      chat: {\n        id: chatId\n      }\n    }\n  }];\n}\n\n// Если режим cake\nif (mode === 'cake') {\n  return [{\n    message: {\n      text: `/cake ${text}`,\n      chat: {\n        id: chatId\n      }\n    }\n  }];\n}\n\n// Если режима нет\nreturn [{\n  message: {\n    text,\n    chat: {\n      id: chatId\n    }\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
