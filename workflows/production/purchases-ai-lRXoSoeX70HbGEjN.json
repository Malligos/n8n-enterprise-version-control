    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nlet message = '📦 *Перевір накладну перед записом:*\\n\\n';\nlet total = 0;\n\nfor (const item of items) {\n  const product = item.json.product || 'Невідомо';\n  const quantity = item.json.quantity || '';\n  const price = item.json.price || '';\n  const sum = Number(item.json.total || 0);\n\n  total += sum;\n\n  message += `• *${product}*\\n`;\n  message += `  К-сть: ${quantity}\\n`;\n  message += `  Ціна: ${price} грн\\n`;\n  message += `  Сума: ${sum} грн\\n\\n`;\n}\n\nmessage += `💰 *Разом:* ${total} грн`;\n\nreturn [{\n  json: {\n    chatId: $('Telegram Trigger').first().json.message.chat.id,\n    message,\n    invoiceData: items.map(i => i.json)\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
