    {
      "parameters": {
        "jsCode": "const today = new Date();\n\nconst currentDay = today.getDate();\n\nconst reminders = [];\n\nfor (const item of items) {\n\n  const paymentDay = Number(item.json.Day);\n  const reminderDays = Number(item.json[\"Reminder Days\"]);\n\n  const daysLeft = paymentDay - currentDay;\n\n  if (daysLeft === reminderDays) {\n\n    reminders.push({\n      json: {\n        payment_name: item.json.Name,\n        amount: item.json.Amount,\n        category: item.json.Category,\n        payment_day: paymentDay,\n        days_left: daysLeft\n      }\n    });\n\n  }\n\n}\n\nreturn reminders;"
      },
